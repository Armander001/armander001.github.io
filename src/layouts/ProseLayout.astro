---
/**
 * ProseLayout.astro — wraps BaseLayout for article-shaped pages (notes,
 * project detail). Renders a narrow header (kicker/title/dek/date) above
 * a `.prose`-styled slot for MDX or hand-written body content.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';

interface Props {
  title: string;
  description: string;
  kicker?: string;
  dek?: string;
  date?: Date;
  ogImage?: string;
}

const { title, description, kicker, dek, date, ogImage } = Astro.props;

const dateLabel = date
  ? date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : undefined;
---

<BaseLayout {title} {description} {ogImage} type="article">
  <Section containerClass="max-w-3xl">
    <header class="mb-10 md:mb-14">
      {
        (kicker || dateLabel) && (
          <p class="mb-3 font-mono text-xs tracking-[0.2em] text-cyan uppercase">
            {kicker}
            {kicker && dateLabel && ' · '}
            {dateLabel && <time datetime={date?.toISOString()}>{dateLabel}</time>}
          </p>
        )
      }
      <h1>{title}</h1>
      {dek && <p class="mt-4 text-lg text-ink-mute">{dek}</p>}
    </header>
    <div class="prose">
      <slot />
    </div>
  </Section>
</BaseLayout>
