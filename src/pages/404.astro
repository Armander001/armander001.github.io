---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Button from '@/components/Button.astro';
import ContourDivider from '@/components/ContourDivider.astro';

const title = 'Page not found';
const description = 'This page does not exist.';
---

<BaseLayout {title} {description}>
  <Section class="pt-32 pb-32 text-center">
    <div class="mx-auto max-w-md text-line">
      <ContourDivider />
    </div>
    <h1 class="mt-8">You've drifted off the chart.</h1>
    <p class="mx-auto mt-4 max-w-sm text-ink-mute">
      The page you're looking for isn't here.
    </p>
    <div class="mt-10">
      <Button href="/" variant="solid">Back home</Button>
    </div>
  </Section>
</BaseLayout>
