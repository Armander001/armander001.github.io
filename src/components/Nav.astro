---
/**
 * Nav.astro — sticky site header.
 * Desktop: inline links with mono index numbers + ThemeToggle.
 * Mobile (<md): hamburger opens a full-screen overlay (focus-trapped,
 * Esc closes, links close on click). Header gains a translucent
 * backdrop-blur once the page is scrolled.
 */
import { site } from '@/config/site';
import ThemeToggle from '@/components/ThemeToggle.astro';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  pathname === href || pathname.startsWith(`${href}/`);
---

<header class="site-header sticky top-0 z-50 border-b border-transparent transition-colors duration-300" data-site-header>
  <div class="container-site flex h-16 items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2.5 text-ink" aria-label={`${site.name} — home`}>
      <!-- contour-ring mark (matches favicon) -->
      <svg class="size-7 text-cyan" viewBox="0 0 64 64" fill="none" aria-hidden="true">
        <g stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <path stroke-width="3.5" d="M32 24.5c4.6-.4 8.6 2.6 9 6.8.4 4.4-3 8.1-7.6 8.5-4.7.4-8.9-2.7-9.3-7-.4-4.2 3.2-7.9 7.9-8.3Z"></path>
          <path stroke-width="2.75" opacity="0.85" d="M31 16.5c9.4-.9 17.6 4.9 18.6 13.2 1 8.6-5.8 16.4-15.3 17.3-9.6.9-18.2-5.4-19.1-14-.9-8.4 6.3-15.6 15.8-16.5Z"></path>
          <path stroke-width="2" opacity="0.6" d="M30 8.5C43.9 7 56.4 15.4 58 27.6c1.6 12.8-8.4 24.5-22.5 25.9C21.3 54.9 8.4 45.8 7 33 5.6 20.7 16.1 10 30 8.5Z"></path>
        </g>
      </svg>
      <span class="font-display text-lg font-medium tracking-tight">{site.name}</span>
    </a>

    <div class="flex items-center gap-2">
      <!-- Desktop nav -->
      <nav aria-label="Primary" class="hidden md:block">
        <ul class="flex items-center gap-5">
          {
            site.nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={isActive(item.href) ? 'page' : undefined}
                  class:list={[
                    'group text-sm transition-colors duration-200',
                    isActive(item.href) ? 'text-ink' : 'text-ink-mute hover:text-ink',
                  ]}
                >
                  <span class="font-mono text-[0.6875rem] text-cyan/70" aria-hidden="true">
                    {item.monoIndex}
                  </span>
                  <span
                    class:list={[
                      'ml-1 underline-offset-4',
                      isActive(item.href)
                        ? 'underline decoration-cyan'
                        : 'group-hover:underline group-hover:decoration-cyan/50',
                    ]}
                  >
                    {item.label}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <ThemeToggle />

      <!-- Mobile menu button -->
      <button
        type="button"
        class="inline-flex size-9 items-center justify-center rounded-full border border-line text-ink-mute transition-colors duration-200 hover:border-cyan hover:text-cyan md:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
        data-menu-toggle
      >
        <svg class="size-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path class="icon-open" d="M3 6h18M3 12h18M3 18h18"></path>
          <path class="icon-close" d="M6 6l12 12M18 6L6 18" style="display: none"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile overlay menu -->
  <div
    id="mobile-menu"
    class="fixed inset-0 top-16 z-40 hidden overflow-y-auto bg-abyss/95 backdrop-blur-md md:hidden"
    data-menu-panel
  >
    <nav aria-label="Primary, mobile" class="container-site py-10">
      <ul class="flex flex-col gap-1">
        {
          site.nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
                class:list={[
                  'flex items-baseline gap-3 rounded-lg px-3 py-3 font-display text-2xl transition-colors duration-200',
                  isActive(item.href) ? 'text-cyan' : 'text-ink hover:text-cyan',
                ]}
              >
                <span class="font-mono text-xs text-ink-mute" aria-hidden="true">
                  {item.monoIndex}
                </span>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  /* Translucent abyss + blur once scrolled (class added by script below). */
  .site-header {
    background-color: transparent;
  }
  .site-header.is-scrolled {
    background-color: color-mix(in srgb, var(--t-abyss) 80%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom-color: var(--t-line);
  }
  /* While the mobile menu is open, keep the header opaque enough to read. */
  .site-header.menu-open {
    background-color: color-mix(in srgb, var(--t-abyss) 92%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom-color: var(--t-line);
  }
</style>

<script>
  function initHeader() {
    const header = document.querySelector<HTMLElement>('[data-site-header]');
    if (!header) return;

    /* Scrolled state */
    const onScroll = () => {
      header.classList.toggle('is-scrolled', window.scrollY > 8);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    /* Mobile overlay menu */
    const toggle = header.querySelector<HTMLButtonElement>('[data-menu-toggle]');
    const panel = header.querySelector<HTMLElement>('[data-menu-panel]');
    if (!toggle || !panel) return;

    const iconOpen = toggle.querySelector<SVGPathElement>('.icon-open');
    const iconClose = toggle.querySelector<SVGPathElement>('.icon-close');
    let open = false;

    const focusables = () =>
      Array.from(
        panel.querySelectorAll<HTMLElement>('a[href], button:not([disabled])'),
      );

    const setOpen = (next: boolean) => {
      open = next;
      panel.classList.toggle('hidden', !open);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      if (iconOpen) iconOpen.style.display = open ? 'none' : '';
      if (iconClose) iconClose.style.display = open ? '' : 'none';
      header.classList.toggle('menu-open', open);
      document.documentElement.style.overflow = open ? 'hidden' : '';
      if (open) focusables()[0]?.focus();
    };

    toggle.addEventListener('click', () => setOpen(!open));

    /* Links close the menu on click */
    panel.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) setOpen(false);
    });

    /* Esc closes, focus returns to the toggle; Tab is trapped in the panel */
    document.addEventListener('keydown', (e) => {
      if (!open) return;
      if (e.key === 'Escape') {
        setOpen(false);
        toggle.focus();
        return;
      }
      if (e.key === 'Tab') {
        const items = [toggle, ...focusables()];
        const first = items[0];
        const last = items[items.length - 1];
        if (!first || !last) return;
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    /* Reset if resized up to desktop */
    window.matchMedia('(min-width: 768px)').addEventListener('change', (e) => {
      if (e.matches && open) setOpen(false);
    });
  }

  initHeader();
</script>
