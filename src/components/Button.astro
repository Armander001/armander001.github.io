---
/**
 * Button.astro — renders an <a> when `href` is given, otherwise <button>.
 * Variants: "solid" (coral CTA), "outline" (cyan), "ghost" (quiet).
 * Usage: <Button href="/projects" variant="solid">View work</Button>
 */
interface Props {
  href?: string;
  variant?: 'solid' | 'outline' | 'ghost';
  type?: 'button' | 'submit';
  class?: string;
}

const { href, variant = 'solid', type = 'button', class: className } = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium transition-all duration-200';

const variants: Record<string, string> = {
  // Fixed dark text (not the theme-switching `ink`/`abyss` tokens) — coral is
  // a bright accent in both themes, so dark-on-coral is correct either way.
  // Verified 7.49:1 (dark theme) / 4.77:1 (light theme) against WCAG AA.
  solid: 'bg-coral text-[#050505] hover:brightness-110 hover:-translate-y-px',
  outline:
    'border border-cyan/50 text-cyan hover:border-cyan hover:bg-cyan/10 hover:-translate-y-px',
  ghost: 'text-ink-mute hover:text-cyan',
};

const classes = [base, variants[variant], className];
const Element = href ? 'a' : 'button';
---

<Element
  href={href}
  type={href ? undefined : type}
  class:list={classes}
>
  <slot />
</Element>
