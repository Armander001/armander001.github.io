---
/**
 * SEO.astro — all document metadata for the <head>.
 * Title template: "%s — A. Benavidez"; pass `isHome` for the bare site name.
 * Usage: <SEO title="About" description="..." /> inside <head>.
 */
import { site } from '@/config/site';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  type?: 'website' | 'article';
  /** Home page passes true to use the title as-is (no "— name" suffix). */
  isHome?: boolean;
}

const {
  title,
  description,
  ogImage = '/og-default.png',
  type = 'website',
  isHome = false,
} = Astro.props;

const fullTitle = isHome ? title : `${title} — ${site.name}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? site.url);
const ogImageUrl = new URL(ogImage, Astro.site ?? site.url);
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

<meta property="og:site_name" content={site.name} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content={type} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<meta name="theme-color" content="#050D16" />
