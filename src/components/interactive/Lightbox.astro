---
/**
 * Lightbox.astro — gallery grid + shared native <dialog> viewer (SPEC §5.5).
 * Masonry-ish CSS-columns grid of thumbnail buttons; clicking one opens the
 * single dialog this component renders, showing the item large with title,
 * caption and a "3 / 12" counter.
 *
 * Props:
 *   items: {
 *     id: string;         // stable key
 *     title: string;
 *     caption?: string;
 *     alt: string;        // for real images; art placeholders are decorative
 *     art?: ArtVariant;   // used when no src — shares PlaceholderArt with ProjectCard
 *     src?: string;       // real image URL (optional)
 *   }[]
 *   columns?: 2 | 3 | 4   (default 3)
 *   class?: string
 *
 * A11y: thumbs are <button aria-haspopup="dialog"> labelled by item title;
 * ArrowLeft/ArrowRight navigate, Esc closes (native), backdrop click closes,
 * focus returns to the originating thumbnail on close. Counter is
 * aria-live="polite" so navigation is announced. No-JS: grid renders as
 * static content (dialog stays closed).
 */
import PlaceholderArt from '@/components/interactive/PlaceholderArt.astro';
import type { ArtVariant } from '@/components/interactive/PlaceholderArt.astro';

export interface LightboxItem {
  id: string;
  title: string;
  caption?: string;
  alt: string;
  art?: ArtVariant;
  src?: string;
}

interface Props {
  items: LightboxItem[];
  columns?: 2 | 3 | 4;
  class?: string;
}

const { items, columns = 3, class: className } = Astro.props;

const colClasses: Record<2 | 3 | 4, string> = {
  2: 'sm:columns-2',
  3: 'sm:columns-2 lg:columns-3',
  4: 'sm:columns-2 md:columns-3 lg:columns-4',
};

/* seed art per item index so identical variants still differ */
const artSeed = (i: number) => i * 7 + 3;
---

<div class:list={['lightbox', className]} data-lightbox>
  <div class:list={['lb-grid', colClasses[columns]]}>
    {
      items.map((item, i) => (
        <button
          type="button"
          class="lb-thumb group"
          data-lb-open={String(i)}
          aria-haspopup="dialog"
          aria-label={`View “${item.title}”`}
        >
          {item.src ? (
            <img src={item.src} alt={item.alt} loading="lazy" class="block w-full" />
          ) : (
            <PlaceholderArt variant={item.art ?? 'reef'} seed={artSeed(i)} />
          )}
          <span class="lb-thumb-title">{item.title}</span>
        </button>
      ))
    }
  </div>

  <dialog class="lb-dialog" aria-label="Gallery viewer">
    <div class="lb-frame">
      <button type="button" class="lb-btn lb-close" data-lb-close aria-label="Close gallery">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true" focusable="false">
          <path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
        </svg>
      </button>

      <div class="lb-stage">
        {
          items.map((item, i) => (
            <figure class="lb-item" data-lb-item hidden={i !== 0}>
              {item.src ? (
                <img src={item.src} alt={item.alt} class="lb-media" />
              ) : (
                <PlaceholderArt variant={item.art ?? 'reef'} seed={artSeed(i)} class="lb-media" />
              )}
              <figcaption class="lb-caption">
                <span class="font-display text-ink">{item.title}</span>
                {item.caption && <span class="block text-sm text-ink-mute">{item.caption}</span>}
              </figcaption>
            </figure>
          ))
        }
      </div>

      <div class="lb-bar">
        <button type="button" class="lb-btn" data-lb-prev aria-label="Previous item">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true" focusable="false">
            <path d="M15 5l-7 7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
        <p class="lb-counter" data-lb-counter aria-live="polite">1 / {items.length}</p>
        <button type="button" class="lb-btn" data-lb-next aria-label="Next item">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true" focusable="false">
            <path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>
    </div>
  </dialog>
</div>

<style>
  .lb-grid {
    column-gap: 1rem;
  }

  .lb-thumb {
    display: block;
    width: 100%;
    margin-block-end: 1rem;
    break-inside: avoid;
    overflow: hidden;
    border: 1px solid var(--t-line);
    border-radius: 0.75rem;
    background-color: var(--t-surface);
    text-align: left;
    cursor: zoom-in;
    transition:
      transform 250ms var(--ease-out-soft),
      border-color 250ms var(--ease-out-soft);
  }

  .lb-thumb:hover,
  .lb-thumb:focus-visible {
    transform: translateY(-3px);
    border-color: var(--t-cyan);
  }

  .lb-thumb:focus-visible {
    outline: 2px solid var(--t-cyan);
    outline-offset: 3px;
  }

  .lb-thumb-title {
    display: block;
    padding: 0.5rem 0.75rem;
    border-top: 1px solid var(--t-line);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--t-ink-mute);
  }

  .lb-thumb:hover .lb-thumb-title,
  .lb-thumb:focus-visible .lb-thumb-title {
    color: var(--t-cyan);
  }

  /* ---- dialog ---- */
  .lb-dialog {
    width: min(64rem, calc(100vw - 2rem));
    max-height: calc(100dvh - 2rem);
    margin: auto;
    padding: 0;
    border: 1px solid var(--t-line);
    border-radius: 1rem;
    background-color: var(--t-surface);
    color: var(--t-ink);
  }

  .lb-dialog::backdrop {
    background: rgb(5 13 22 / 0.8); /* fallback */
    background: color-mix(in srgb, var(--t-abyss) 80%, transparent);
    backdrop-filter: blur(6px);
  }

  .lb-frame {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 1rem;
  }

  .lb-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 2;
  }

  .lb-item[hidden] {
    display: none;
  }

  .lb-item :global(.lb-media) {
    display: block;
    width: 100%;
    height: auto;
    max-height: calc(100dvh - 14rem);
    object-fit: contain;
    border-radius: 0.5rem;
    border: 1px solid var(--t-line);
  }

  .lb-caption {
    margin-block-start: 0.75rem;
    padding-inline-end: 3rem;
    line-height: 1.5;
  }

  .lb-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-block-start: 1rem;
    border-top: 1px solid var(--t-line);
    padding-block-start: 0.875rem;
  }

  .lb-counter {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    color: var(--t-ink-mute);
  }

  .lb-btn {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid var(--t-line);
    border-radius: 9999px;
    background-color: var(--t-surface-2);
    color: var(--t-ink);
    cursor: pointer;
    transition:
      border-color 200ms var(--ease-out-soft),
      color 200ms var(--ease-out-soft);
  }

  .lb-btn:hover,
  .lb-btn:focus-visible {
    border-color: var(--t-cyan);
    color: var(--t-cyan);
  }

  .lb-btn:focus-visible {
    outline: 2px solid var(--t-cyan);
    outline-offset: 2px;
  }
</style>

<script>
  function initLightbox(root: HTMLElement): void {
    const dialog = root.querySelector<HTMLDialogElement>('dialog');
    const figures = Array.from(root.querySelectorAll<HTMLElement>('[data-lb-item]'));
    const counter = root.querySelector<HTMLElement>('[data-lb-counter]');
    const thumbs = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-lb-open]'));
    if (!dialog || figures.length === 0) return;

    let current = 0;
    let opener: HTMLElement | null = null;

    function show(i: number): void {
      current = (i + figures.length) % figures.length;
      figures.forEach((f, j) => f.toggleAttribute('hidden', j !== current));
      if (counter) counter.textContent = `${current + 1} / ${figures.length}`;
    }

    thumbs.forEach((btn) => {
      btn.addEventListener('click', () => {
        opener = btn;
        show(Number(btn.dataset.lbOpen ?? '0'));
        dialog.showModal();
      });
    });

    dialog.querySelector('[data-lb-prev]')?.addEventListener('click', () => show(current - 1));
    dialog.querySelector('[data-lb-next]')?.addEventListener('click', () => show(current + 1));
    dialog.querySelector('[data-lb-close]')?.addEventListener('click', () => dialog.close());

    dialog.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        show(current - 1);
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        show(current + 1);
      }
    });

    /* click on the backdrop area (the dialog element itself) closes */
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });

    /* Esc is native; on any close, restore focus to the opening thumbnail */
    dialog.addEventListener('close', () => {
      opener?.focus();
    });
  }

  document.querySelectorAll<HTMLElement>('[data-lightbox]').forEach(initLightbox);
</script>
