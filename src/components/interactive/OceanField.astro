---
/**
 * OceanField.astro — animated hero background (SPEC §5.1).
 * A 2D canvas filling its (positioned) parent behind content: slow-drifting
 * marine-snow particles + faint undulating bathymetric contour lines.
 * A CSS radial-glow gradient layer always sits under the canvas, so no-JS
 * and reduced-motion users still get the abyssal atmosphere.
 *
 * Usage — parent must be `position: relative` (or similar); content above
 * needs its own positive z-index/`relative`:
 *   <div class="relative">
 *     <OceanField />
 *     <div class="relative">hero content</div>
 *   </div>
 *
 * Props: class? — extra classes for the wrapper (default: absolute inset-0).
 *
 * Behavior: colors read from --t-cyan/--t-teal/--t-ink-mute (re-read on
 * html[data-theme] change); devicePixelRatio capped at 2; rAF paused when
 * document.hidden or canvas offscreen; prefers-reduced-motion → single
 * static frame, no animation. Entirely decorative (aria-hidden).
 */
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div
  class:list={['pointer-events-none absolute inset-0 overflow-hidden', className]}
  aria-hidden="true"
>
  <div class="ocean-glow absolute inset-0"></div>
  <canvas data-ocean-field class="absolute inset-0 h-full w-full"></canvas>
</div>

<style>
  /* Static fallback: subtle cyan/teal radial glows on the abyss (SPEC §3). */
  .ocean-glow {
    background:
      radial-gradient(
        55% 45% at 22% 12%,
        color-mix(in srgb, var(--t-cyan) 7%, transparent),
        transparent 70%
      ),
      radial-gradient(
        45% 40% at 78% 28%,
        color-mix(in srgb, var(--t-teal) 6%, transparent),
        transparent 70%
      ),
      radial-gradient(
        70% 55% at 50% 105%,
        color-mix(in srgb, var(--t-cyan) 5%, transparent),
        transparent 72%
      );
  }
</style>

<script>
  /* OceanField engine — vanilla TS, no dependencies. Initializes every
     [data-ocean-field] canvas on the page (script bundles/runs once). */

  interface Particle {
    x: number;
    y: number;
    r: number;
    vx: number;
    vy: number;
    a: number;
    phase: number;
  }

  interface Contour {
    yFrac: number;
    amp: number;
    phase: number;
    speed: number;
    freq: number;
  }

  function initOceanField(canvas: HTMLCanvasElement): void {
    const ctx = canvas.getContext('2d');
    const host = canvas.parentElement;
    if (!ctx || !host) return;

    const root = document.documentElement;
    const reduceMq = window.matchMedia('(prefers-reduced-motion: reduce)');

    let colors = readColors();
    let w = 0;
    let h = 0;
    let dpr = 1;
    let particles: Particle[] = [];
    let rafId = 0;
    let running = false;
    let inView = true;
    let time = Math.random() * 1000;
    let last = 0;

    const contours: Contour[] = [
      { yFrac: 0.3, amp: 14, phase: 0.0, speed: 0.1, freq: 0.006 },
      { yFrac: 0.52, amp: 18, phase: 2.1, speed: 0.08, freq: 0.005 },
      { yFrac: 0.68, amp: 12, phase: 4.4, speed: 0.12, freq: 0.007 },
      { yFrac: 0.85, amp: 16, phase: 1.3, speed: 0.07, freq: 0.0045 },
    ];

    function readColors() {
      const s = getComputedStyle(root);
      return {
        cyan: s.getPropertyValue('--t-cyan').trim() || '#4fd8eb',
        teal: s.getPropertyValue('--t-teal').trim() || '#2dd4a8',
        mute: s.getPropertyValue('--t-ink-mute').trim() || '#8fa6ba',
      };
    }

    function resize(): void {
      w = host!.clientWidth;
      h = host!.clientHeight;
      if (w === 0 || h === 0) return;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      seedParticles();
    }

    function seedParticles(): void {
      /* density scaled by area, hard cap 120 */
      const count = Math.min(120, Math.max(30, Math.round((w * h) / 14000)));
      particles = Array.from({ length: count }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        r: 0.6 + Math.random() * 1.5,
        vx: 2 + Math.random() * 6, // px/s lateral current
        vy: 3 + Math.random() * 8, // px/s slow sink
        a: 0.12 + Math.random() * 0.4,
        phase: Math.random() * Math.PI * 2,
      }));
    }

    function draw(dt: number): void {
      ctx!.clearRect(0, 0, w, h);

      /* bathymetric contour polylines */
      ctx!.lineWidth = 1;
      for (let i = 0; i < contours.length; i++) {
        const c = contours[i]!;
        ctx!.strokeStyle = i % 2 === 0 ? colors.teal : colors.cyan;
        ctx!.globalAlpha = 0.07;
        ctx!.beginPath();
        const baseY = c.yFrac * h;
        for (let x = -8; x <= w + 8; x += 14) {
          const y =
            baseY +
            Math.sin(x * c.freq + time * c.speed + c.phase) * c.amp +
            Math.sin(x * c.freq * 2.7 - time * c.speed * 0.6 + c.phase) * c.amp * 0.35;
          if (x === -8) ctx!.moveTo(x, y);
          else ctx!.lineTo(x, y);
        }
        ctx!.stroke();
      }

      /* marine snow */
      for (const p of particles) {
        p.x += (p.vx + Math.sin(time * 0.4 + p.phase) * 3) * dt;
        p.y += p.vy * dt;
        if (p.y > h + 4) {
          p.y = -4;
          p.x = Math.random() * w;
        }
        if (p.x > w + 4) p.x = -4;
        else if (p.x < -4) p.x = w + 4;
        ctx!.globalAlpha = p.a * (0.75 + 0.25 * Math.sin(time * 1.1 + p.phase));
        ctx!.fillStyle = p.r > 1.5 ? colors.cyan : colors.mute;
        ctx!.beginPath();
        ctx!.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx!.fill();
      }
      ctx!.globalAlpha = 1;
    }

    function frame(ts: number): void {
      if (!running) return;
      const dt = last === 0 ? 0.016 : Math.min((ts - last) / 1000, 0.05);
      last = ts;
      time += dt;
      draw(dt);
      rafId = requestAnimationFrame(frame);
    }

    function start(): void {
      if (running || reduceMq.matches || document.hidden || !inView) return;
      running = true;
      last = 0;
      rafId = requestAnimationFrame(frame);
    }

    function stop(): void {
      running = false;
      if (rafId) cancelAnimationFrame(rafId);
      rafId = 0;
    }

    function staticFrame(): void {
      draw(0);
    }

    /* --- wiring --- */
    resize();
    if (reduceMq.matches) staticFrame();
    else start();

    reduceMq.addEventListener('change', () => {
      if (reduceMq.matches) {
        stop();
        staticFrame();
      } else {
        start();
      }
    });

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop();
      else start();
    });

    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        inView = e.isIntersecting;
        if (inView) start();
        else stop();
      }
    });
    io.observe(canvas);

    const ro = new ResizeObserver(() => {
      resize();
      if (!running) staticFrame();
    });
    ro.observe(host);

    /* re-read palette when the theme toggles */
    new MutationObserver(() => {
      colors = readColors();
      if (!running) staticFrame();
    }).observe(root, { attributes: true, attributeFilter: ['data-theme'] });
  }

  document
    .querySelectorAll<HTMLCanvasElement>('canvas[data-ocean-field]')
    .forEach(initOceanField);
</script>
