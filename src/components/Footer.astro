---
/**
 * Footer.astro — contour divider on the top edge, then three columns:
 * mission line · secondary links · social links (from site.ts).
 * Placeholder socials render with an "add link" title but stay visible.
 */
import { site } from '@/config/site';
import ContourDivider from '@/components/ContourDivider.astro';

const year = new Date().getFullYear();

const secondaryLinks = [
  { label: 'Contact', href: '/contact' },
  { label: 'Now', href: '/now' },
  { label: 'Publications', href: '/publications' },
  { label: 'Visualizations', href: '/visualizations' },
];
---

<footer class="mt-24">
  <div class="text-line" aria-hidden="true">
    <ContourDivider />
  </div>

  <div class="border-t border-line bg-surface/40">
    <div class="container-site grid gap-10 py-14 sm:grid-cols-2 lg:grid-cols-3">
      <div class="max-w-xs">
        <p class="font-display text-lg leading-snug text-ink">{site.tagline}</p>
        <p class="mt-3 font-mono text-xs leading-relaxed text-ink-mute">{site.role}</p>
      </div>

      <nav aria-label="Footer">
        <h2 class="font-mono text-xs tracking-widest text-ink-mute uppercase">Explore</h2>
        <ul class="mt-4 space-y-2">
          {
            secondaryLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-ink-mute underline-offset-4 transition-colors duration-200 hover:text-cyan hover:underline"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div>
        <h2 class="font-mono text-xs tracking-widest text-ink-mute uppercase">Elsewhere</h2>
        <ul class="mt-4 space-y-2">
          {
            site.social.map((link) => (
              <li>
                <a
                  href={link.href}
                  title={link.placeholder ? 'Add link in src/config/site.ts' : undefined}
                  class:list={[
                    'text-sm underline-offset-4 transition-colors duration-200 hover:text-cyan hover:underline',
                    link.placeholder ? 'text-ink-mute/60' : 'text-ink-mute',
                  ]}
                  {...(link.placeholder ? {} : { rel: 'me noopener', target: '_blank' })}
                >
                  {link.label}
                  {link.placeholder && (
                    <span class="ml-1 font-mono text-[0.625rem] text-ink-mute/50">[soon]</span>
                  )}
                </a>
              </li>
            ))
          }
          <li>
            <a
              href={`mailto:${site.email}`}
              class="text-sm text-ink-mute underline-offset-4 transition-colors duration-200 hover:text-cyan hover:underline"
            >
              {site.email}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-line">
      <div class="container-site flex flex-wrap items-center justify-between gap-2 py-5">
        <p class="font-mono text-xs text-ink-mute">© {year} {site.name}</p>
        <p class="font-mono text-xs text-ink-mute">
          Built with <a href="https://astro.build" class="underline-offset-4 hover:text-cyan hover:underline" rel="noopener" target="_blank">Astro</a>
        </p>
      </div>
    </div>
  </div>
</footer>
